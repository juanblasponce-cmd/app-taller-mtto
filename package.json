{
  "name": "app-taller-mtto",
  "version": "1.0.0",
  "description": "Aplicación de Avisos, Órdenes de Trabajo y Backlog de Mantenimiento Industrial",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "concurrently -n API,WEB -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cross-env API_PORT=3001 nodemon --exec \"node --experimental-sqlite --no-warnings server/index.js\"",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node --experimental-sqlite --no-warnings server/index.js",
    "seed": "node --experimental-sqlite --no-warnings server/db/seed.js --force"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.3",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "vite": "^6.0.7"
  }
}
